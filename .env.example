# Atlas — environment template
# Copy to .env at repo root, or create per-app .env files (backend/.env, frontend/.env.local)

# ─── LLM (planner + synthesizer) ────────────────────────────────────
# Optional during Day 1-2 foundation. If absent, the planner and
# synthesizer fall back to heuristics so the end-to-end pipeline
# still produces a brief in pure mock mode.
ANTHROPIC_API_KEY=
ATLAS_LLM_MODEL=claude-sonnet-4-6

# ─── Bright Data MCP Server ─────────────────────────────────────────
# https://github.com/luminati-io/brightdata-mcp
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_WEB_UNLOCKER_ZONE=
BRIGHTDATA_SCRAPING_BROWSER_ZONE=
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_WEB_SCRAPER_ZONE=

# How to launch the MCP server (stdio transport).
# Default works once @brightdata/mcp is installed via npx.
ATLAS_MCP_COMMAND=npx
ATLAS_MCP_ARGS=-y,@brightdata/mcp

# ─── Mode ───────────────────────────────────────────────────────────
# "mock": every module returns canned fixtures (no Bright Data calls).
# "live": modules attempt real MCP calls; falls back to mock per-module
#         on failure. Live mode is wired up in Days 3+.
ATLAS_MODE=mock

# ─── Backend (FastAPI) ──────────────────────────────────────────────
ATLAS_BACKEND_HOST=127.0.0.1
ATLAS_BACKEND_PORT=8000
ATLAS_CORS_ORIGINS=http://localhost:3000

# ─── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_ATLAS_API=http://localhost:8000
